{
  "name": "migracao-drive-azure",
  "version": "1.0.0",
  "description": "Aplicacao monolitica em Node.js e Express para migrar arquivos do Google Drive para Azure Blob Storage.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:3001": "node -e \"process.env.PORT=3001; require('./src/server')\"",
    "dev": "node --watch src/server.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "google-drive",
    "azure-blob-storage",
    "computacao-em-nuvem"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/storage-blob": "^12.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^172.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
